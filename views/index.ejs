<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SES Viewer</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    #email-list .email-row.selected {
      background-color: rgb(239 246 255);
      border-left: 3px solid rgb(59 130 246);
    }
    #email-list .email-row:not(.selected) {
      border-left: 3px solid transparent;
    }
  </style>
</head>
<body class="bg-gray-100 h-screen flex flex-col overflow-hidden">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200 px-6 py-2 flex items-center justify-between shrink-0">
    <h1 class="text-lg font-bold text-gray-900">SES Viewer</h1>
  </header>

  <!-- Two-pane layout -->
  <div class="flex flex-1 min-h-0">
    <!-- Left sidebar: email list -->
    <div class="w-1/3 min-w-[280px] max-w-[420px] border-r border-gray-200 bg-white flex flex-col">
      <div class="px-3 py-2 border-b border-gray-100 bg-gray-50 shrink-0 flex items-center gap-2">
        <input
          id="email-search"
          type="text"
          placeholder="Search emails..."
          oninput="filterEmails(this.value)"
          class="flex-1 text-sm px-2.5 py-1.5 bg-transparent focus:outline-none placeholder-gray-400"
        >
        <span id="email-count" class="text-xs font-medium text-gray-400 whitespace-nowrap">
          <%= emails.length %> email<%= emails.length !== 1 ? 's' : '' %>
        </span>
      </div>
      <div id="email-list" class="flex-1 overflow-y-auto">
        <%- include("partials/email_list", { emails }) %>
      </div>
    </div>

    <!-- Right pane: email detail -->
    <div class="flex-1 bg-white flex flex-col">
      <div id="email-detail" class="flex-1 overflow-y-auto">
        <div class="flex flex-col items-center justify-center h-full text-gray-400">
          <p class="text-lg">Select an email to read it</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    let selectedIndex = -1;

    function filterEmails(query) {
      const q = query.toLowerCase();
      const rows = document.querySelectorAll('#email-list .email-row');
      let visible = 0;
      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        const match = !q || text.includes(q);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      document.getElementById('email-count').textContent = visible + ' email' + (visible !== 1 ? 's' : '');
    }

    function selectEmail(index) {
      selectedIndex = index;

      // Highlight the selected row
      document.querySelectorAll('#email-list .email-row').forEach((row, i) => {
        row.classList.toggle('selected', i === index);
      });

      // Fetch and render the email detail
      fetch('/emails/' + index)
        .then(res => {
          if (!res.ok) throw new Error('Failed to fetch email detail');
          return res.text();
        })
        .then(html => {
          document.getElementById('email-detail').innerHTML = html;
        })
        .catch(() => {
          document.getElementById('email-detail').innerHTML =
            '<div class="flex items-center justify-center h-full text-red-400"><p>Failed to load email</p></div>';
        });
    }

    // Polling: refresh the sidebar every 5 seconds
    setInterval(async () => {
      try {
        const res = await fetch('/emails');
        if (!res.ok) return;
        const html = await res.text();
        const list = document.getElementById('email-list');
        list.innerHTML = html;

        // Re-apply search filter and update count
        const searchVal = document.getElementById('email-search').value;
        if (searchVal) {
          filterEmails(searchVal);
        } else {
          const c = list.querySelectorAll('.email-row').length;
          document.getElementById('email-count').textContent =
            c + ' email' + (c !== 1 ? 's' : '');
        }

        // Re-apply selection
        const rows = list.querySelectorAll('.email-row');
        if (selectedIndex >= 0 && selectedIndex < rows.length) {
          rows[selectedIndex].classList.add('selected');
        } else if (selectedIndex >= rows.length) {
          // Selected email no longer exists, clear detail
          selectedIndex = -1;
          document.getElementById('email-detail').innerHTML =
            '<div class="flex flex-col items-center justify-center h-full text-gray-400">' +
              '<p class="text-lg">Select an email to read it</p>' +
            '</div>';
        }

        // Auto-select first email if none selected
        if (selectedIndex === -1 && rows.length > 0) {
          selectEmail(0);
        }
      } catch (e) {
        // silently retry on next interval
      }
    }, 5000);

    // Auto-select first email on initial load
    document.addEventListener('DOMContentLoaded', () => {
      const rows = document.querySelectorAll('#email-list .email-row');
      if (rows.length > 0) {
        selectEmail(0);
      }
    });
  </script>
</body>
</html>
